#input
input_time = input(" ")
def split_time(input_time):
    try:
        time_list = input_time.split(" : ")
        gio = int(time_list[1])
        phut = int(time_list[2])
        giay = int(time_list[3])
        return gio, phut, giay
    except:
        print(" Invalid, time for mat")
        return None
def validate_time(gio = None, phut = None, giay = None):
        if gio == None or phut == None or giay == None:
            return "Không hợp lệ"
        if gio < 0 or gio > 23:
            return "Không hợp lệ"
        if phut < 0 or phut > 59:
            return "Không hợp lệ"
        if giay < 0 or giay > 59:
            return "Không hợp lệ"
        
        return "hợp lệ"
        
print(validate_time(*split_time(input_time)))
    
    
    
    
            

